<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:background="@drawable/main_content_rectangle_selector"
	android:layout_height="@dimen/toolpage_public_tree_item_icon_WH">
	
	<ImageView
		android:id="@+id/iv_icon"
		android:layout_width="@dimen/toolpage_public_tree_item_icon_WH"
		android:layout_height="@dimen/toolpage_public_tree_item_icon_WH"
		android:padding="@dimen/toolpage_public_tree_item_icon_padding"
		android:scaleType="fitCenter" />
	
	<TextView
		android:id="@+id/tv_name"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:layout_marginEnd="5dp"
		android:ellipsize="end"
		android:gravity="center_vertical"
		android:singleLine="true"
		android:textColor="?attr/main_content_foreground_color"
		android:textSize="@dimen/toolpage_public_tree_item_text_size"
		tools:text="@string/app_name" />
</LinearLayout>