<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/find_layout"
    android:layout_width="match_parent"
    android:layout_height="@dimen/toolbar_menu_layout_H"
    android:background="?attr/main_bottom_background_color"
    android:elevation="2dp"
    android:visibility="gone"
    app:layout_constraintBottom_toTopOf="@+id/replace_layout"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    tools:visibility="visible"
    tools:showIn="@layout/contents_codeeditor">

    <EditText
        android:id="@+id/find_edit_input"
        style="@style/Main.Bottom.Text.CodeEditor_FindReplace_EditText"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:hint="@string/contents_codeeditor_findreplace_find_text"
        android:importantForAutofill="no"
        android:textColor="?attr/main_bottom_foreground_color"
        android:textColorHint="?attr/main_bottom_foreground_color_hint" />

    <ImageButton
        android:id="@+id/find_ibtn_prior"
        style="@style/Main.Bottom.Image.Button.Round.CodeEditor_FindReplace"
        android:layout_width="@dimen/toolbar_menu_layout_H"
        android:layout_height="@dimen/toolbar_menu_layout_H"
        app:srcCompat="@drawable/codeeditor_findreplace_prior" />

    <ImageButton
        android:id="@+id/find_ibtn_next"
        style="@style/Main.Bottom.Image.Button.Round.CodeEditor_FindReplace"
        android:layout_width="@dimen/toolbar_menu_layout_H"
        android:layout_height="@dimen/toolbar_menu_layout_H"
        app:srcCompat="@drawable/codeeditor_findreplace_next" />

    <ImageButton
        android:id="@+id/find_ibtn_case"
        style="@style/Main.Bottom.Image.Button.Round.CodeEditor_FindReplace"
        android:layout_width="@dimen/toolbar_menu_layout_H"
        android:layout_height="@dimen/toolbar_menu_layout_H"
        android:src="@drawable/codeeditor_findreplace_case" />

    <ImageButton
        android:id="@+id/find_ibtn_regex"
        style="@style/Main.Bottom.Image.Button.Round.CodeEditor_FindReplace"
        android:layout_width="@dimen/toolbar_menu_layout_H"
        android:layout_height="@dimen/toolbar_menu_layout_H"
        android:src="@drawable/codeeditor_findreplace_regex" />

    <ImageButton
        android:id="@+id/find_ibtn_close"
        style="@style/Main.Bottom.Image.Button.Round.CodeEditor_FindReplace"
        android:layout_width="@dimen/toolbar_menu_layout_H"
        android:layout_height="@dimen/toolbar_menu_layout_H"
        android:src="@drawable/codeeditor_findreplace_close" />
</LinearLayout>