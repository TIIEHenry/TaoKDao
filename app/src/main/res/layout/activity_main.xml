<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:fitsSystemWindows="false"
	tools:ignore="ContentDescription">
	
	<androidx.constraintlayout.widget.ConstraintLayout
		android:id="@+id/main_toolbar_cl"
		android:layout_width="match_parent"
		android:layout_height="0dp"
		android:background="?attr/main_appbar_background_color"
		android:elevation="3dp"
		app:layout_constraintEnd_toEndOf="parent"
		app:layout_constraintStart_toStartOf="parent"
		app:layout_constraintTop_toTopOf="parent">
		
		<ImageView
			android:id="@+id/main_toolbar_navigator_iv"
			android:layout_width="@dimen/toolbar_logo_W"
			android:layout_height="@dimen/toolbar_logo_H"
			android:layout_marginStart="@dimen/toolbar_logo_marginStart"
			android:background="@drawable/toolbar_drawer_selector"
			android:padding="6dp"
			android:scaleType="fitEnd"
			android:src="@drawable/ic_launcher_logo"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintTop_toTopOf="parent" />
		
		<!--		<View-->
		<!--			android:id="@+id/main_toolbar_session"-->
		<!--			android:layout_width="0dp"-->
		<!--			android:layout_height="@dimen/main_toolbar_H"-->
		<!--			app:layout_constraintEnd_toStartOf="@id/main_toolbar_session"-->
		<!--			app:layout_constraintStart_toEndOf="@id/main_toolbar_drawer"-->
		<!--			app:layout_constraintTop_toTopOf="parent" />-->
		
		<androidx.recyclerview.widget.RecyclerView
			android:id="@+id/main_toolbar_quickmenu_rv"
			android:layout_width="0dp"
			android:layout_height="@dimen/toolbar_menu_layout_H"
			android:paddingHorizontal="5dp"
			android:scrollbars="none"
			app:layout_constraintEnd_toStartOf="@id/main_toolbar_menu_rv"
			app:layout_constraintStart_toEndOf="@id/main_toolbar_navigator_iv"
			app:layout_constraintTop_toTopOf="parent" />
		
		<androidx.recyclerview.widget.RecyclerView
			android:id="@+id/main_toolbar_menu_rv"
			android:layout_width="wrap_content"
			android:layout_height="@dimen/toolbar_menu_layout_H"
			android:scrollbars="none"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintTop_toTopOf="parent" />
		
		
		<TextView
			android:id="@+id/main_toolbar_indicator_start_tv"
			android:layout_width="wrap_content"
			android:layout_height="30dp"
			android:background="@drawable/toolbar_indicator_start_selector"
			android:clickable="true"
			android:focusable="true"
			android:gravity="center"
			android:paddingStart="10dp"
			android:paddingEnd="10dp"
			android:textColor="?attr/main_appbar_foreground_color"
			android:textSize="12sp"
			app:layout_constraintBottom_toBottomOf="parent"
			app:layout_constraintStart_toStartOf="parent"
			tools:ignore="TouchTargetSizeCheck"
			tools:text="UTF-8" />
		
		<tiiehenry.taokdao.ui.view.tablayout.TabLayout
			android:id="@+id/main_toolbar_tab_layout"
			android:layout_width="0dp"
			android:layout_height="30dp"
			android:background="?attr/main_appbar_background_color"
			app:layout_constraintEnd_toStartOf="@id/main_toolbar_indicator_end_tv"
			app:layout_constraintStart_toEndOf="@id/main_toolbar_indicator_start_tv"
			app:layout_constraintTop_toBottomOf="@id/main_toolbar_menu_rv"
			app:tabGravity="start"
			app:tabIndicatorAnimationDuration="400"
			app:tabIndicatorColor="?attr/main_appbar_foreground_color"
			app:tabIndicatorHeight="2dp"
			app:tabMinWidth="28dp"
			app:tabMode="scrollable"
			app:tabPaddingEnd="4dp"
			app:tabPaddingStart="4dp"
			app:tabRippleColor="?attr/main_appbar_background_color_accent"
			app:tabSelectedTextColor="?attr/main_appbar_foreground_color_accent"
			app:tabTextColor="?attr/main_appbar_foreground_color"
			app:tabUnboundedRipple="true" />
		
		<TextView
			android:id="@+id/main_toolbar_indicator_end_tv"
			android:layout_width="wrap_content"
			android:layout_height="30dp"
			android:background="@drawable/toolbar_indicator_end_selector"
			android:clickable="true"
			android:focusable="true"
			android:gravity="center"
			android:paddingStart="10dp"
			android:paddingEnd="10dp"
			android:textColor="?attr/main_appbar_foreground_color"
			android:textSize="12sp"
			app:layout_constraintBottom_toBottomOf="parent"
			app:layout_constraintEnd_toEndOf="parent"
			tools:text="1:1" />
	
	
	</androidx.constraintlayout.widget.ConstraintLayout>
	
	
	<tiiehenry.taokdao.ui.content.ContentViewPager
		android:id="@+id/main_body_content_view_pager"
		android:layout_width="match_parent"
		android:layout_height="0dp"
		android:background="?attr/main_content_background_color"
		app:layout_constraintBottom_toTopOf="@id/main_bottom_progress_bar"
		app:layout_constraintEnd_toEndOf="parent"
		app:layout_constraintStart_toStartOf="parent"
		app:layout_constraintTop_toBottomOf="@id/main_toolbar_cl" />
	
	<include
		android:id="@+id/main_content_guider"
		layout="@layout/contents_guider"
		android:layout_width="match_parent"
		android:layout_height="0dp"
		app:layout_constraintBottom_toTopOf="@+id/main_bottom_progress_bar"
		app:layout_constraintEnd_toEndOf="parent"
		app:layout_constraintStart_toStartOf="parent"
		app:layout_constraintTop_toBottomOf="@+id/main_toolbar_cl" />
	
	
	<LinearLayout
		android:id="@+id/main_body_side_ll"
		android:layout_width="wrap_content"
		android:layout_height="26dp"
		android:background="@drawable/main_side_bg"
		android:elevation="2dp"
		android:orientation="vertical"
		app:layout_constraintEnd_toEndOf="parent"
		app:layout_constraintTop_toBottomOf="@id/main_toolbar_cl">
		
		<!--		<TextView-->
		<!--			android:id="@+id/main_side_plugin"-->
		<!--			android:layout_width="50dp"-->
		<!--			android:layout_height="match_parent"-->
		<!--			android:background="@drawable/main_side_selector"-->
		<!--			android:elevation="3dp"-->
		<!--			android:ellipsize="none"-->
		<!--			android:gravity="center"-->
		<!--			android:padding="0dp"-->
		<!--			android:singleLine="true"-->
		<!--			android:text="@string/plugin"-->
		<!--			android:textColor="?attr/main_float_foreground_color"-->
		<!--			android:textSize="13sp"-->
		<!--			android:typeface="serif" />-->
	</LinearLayout>
	
	<ProgressBar
		android:id="@+id/main_bottom_progress_bar"
		style="?android:attr/progressBarStyleHorizontal"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:indeterminate="true"
		android:visibility="gone"
		app:layout_constraintBottom_toBottomOf="parent"
		app:layout_constraintEnd_toEndOf="parent"
		app:layout_constraintStart_toStartOf="parent"
		tools:visibility="visible" />

	<FrameLayout
		android:id="@+id/cl_toolpage_container"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:elevation="6dp"
		android:visibility="gone"
		app:layout_constraintBottom_toBottomOf="parent"
		tools:visibility="gone" />
	<!--	<include-->
	<!--		android:id="@+id/cl_toolpage"-->
	<!--		layout="@layout/toolpage_layout"-->
	<!--		android:layout_width="match_parent"-->
	<!--		android:layout_height="wrap_content"-->
	<!--		android:visibility="gone"-->
	<!--		app:layout_constraintBottom_toBottomOf="parent"-->
	<!--		tools:visibility="gone" />-->
</androidx.constraintlayout.widget.ConstraintLayout>
