<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="@dimen/toolbar_contentlist_item_H">
	
	<LinearLayout
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:background="@drawable/main_content_rectangle_selector">
		
		<ImageView
			android:id="@+id/iv_icon"
			android:layout_width="@dimen/toolbar_contentlist_item_icon_H"
			android:layout_height="@dimen/toolbar_contentlist_item_icon_H"
			android:layout_margin="@dimen/toolbar_contentlist_item_icon_margin"
			android:scaleType="fitCenter" />
		
		<TextView
			android:id="@+id/tv_name"
			android:layout_width="match_parent"
			android:layout_height="match_parent"
			android:layout_marginEnd="5dp"
			android:ellipsize="middle"
			android:gravity="center_vertical"
			android:singleLine="true"
			android:textColor="?attr/main_content_foreground_color"
			android:textSize="15sp"
			android:typeface="serif"
			tools:text="init.js" />
	</LinearLayout>

</FrameLayout>