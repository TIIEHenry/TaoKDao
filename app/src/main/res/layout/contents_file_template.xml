<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:background="?attr/main_content_background_color">
	
	
	<EditText
		android:id="@+id/et_name"
		style="@style/et_file_template_params_input"
		android:layout_width="0dp"
		android:hint="Name"
		android:inputType="textPersonName"
		android:text="template1"
		app:layout_constraintEnd_toStartOf="@id/et_extension"
		app:layout_constraintHorizontal_weight="2"
		app:layout_constraintStart_toStartOf="parent"
		app:layout_constraintTop_toTopOf="parent" />
	
	<EditText
		android:id="@+id/et_extension"
		style="@style/et_file_template_params_input"
		android:layout_width="0dp"
		android:hint="Extension"
		android:text="txt"
		app:layout_constraintEnd_toEndOf="parent"
		app:layout_constraintHorizontal_weight="1"
		app:layout_constraintStart_toEndOf="@+id/et_name"
		app:layout_constraintTop_toTopOf="parent" />
	
	<EditText
		android:id="@+id/et_group"
		style="@style/et_file_template_params_input"
		android:layout_width="0dp"
		android:hint="Group"
		android:inputType="textPersonName"
		android:text=""
		app:layout_constraintEnd_toStartOf="@id/et_description"
		app:layout_constraintHorizontal_weight="1"
		app:layout_constraintStart_toStartOf="parent"
		app:layout_constraintTop_toBottomOf="@id/et_name" />
	
	<EditText
		android:id="@+id/et_description"
		style="@style/et_file_template_params_input"
		android:layout_width="0dp"
		android:hint="Description"
		app:layout_constraintEnd_toEndOf="parent"
		app:layout_constraintHorizontal_weight="3"
		app:layout_constraintStart_toEndOf="@id/et_group"
		app:layout_constraintTop_toBottomOf="@+id/et_extension" />
	
	
	<EditText
		android:id="@+id/et_parameters"
		style="@style/et_file_template_params_input"
		android:layout_width="0dp"
		android:hint="Parameters"
		app:layout_constraintEnd_toEndOf="parent"
		app:layout_constraintHorizontal_weight="4"
		app:layout_constraintStart_toStartOf="parent"
		app:layout_constraintTop_toBottomOf="@id/et_group" />
	
	<include
		android:id="@+id/contents_codeeditor"
		layout="@layout/contents_codeeditor"
		android:layout_width="0dp"
		android:layout_height="0dp"
		app:layout_constraintBottom_toBottomOf="parent"
		app:layout_constraintEnd_toEndOf="parent"
		app:layout_constraintStart_toStartOf="parent"
		app:layout_constraintTop_toBottomOf="@+id/et_parameters" />
</androidx.constraintlayout.widget.ConstraintLayout>