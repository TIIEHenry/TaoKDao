<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:background="@drawable/main_appbar_rectangle_selector"
	android:orientation="horizontal">
	
	<ImageView
		android:id="@+id/iv_icon"
		android:layout_width="@dimen/toolbar_menu_layout_H"
		android:layout_height="@dimen/toolbar_menu_layout_H"
		android:padding="10dp"
		android:scaleType="fitCenter" />
	
	<TextView
		android:id="@+id/tv_label"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:layout_marginEnd="15dp"
		android:ellipsize="end"
		android:gravity="center_vertical"
		android:singleLine="true"
		android:textColor="?attr/main_appbar_foreground_color"
		android:textSize="16sp" />
</LinearLayout>