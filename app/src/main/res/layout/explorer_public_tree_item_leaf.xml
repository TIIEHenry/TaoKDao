<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="@dimen/explorer_public_tree_item_H"
	android:background="@drawable/main_content_rectangle_selector">
	
	<View
		android:id="@+id/v_divider"
		android:layout_width="1dp"
		android:layout_height="match_parent"
		android:layout_marginVertical="8dp"
		android:layout_marginStart="@dimen/explorer_public_tree_item_H"
		android:background="?attr/main_content_background_color_hint" />
	
	<ImageView
		android:id="@+id/iv_icon"
		android:layout_width="@dimen/explorer_public_tree_item_H"
		android:layout_height="@dimen/explorer_public_tree_item_H"
		android:padding="10dp"
		android:scaleType="fitCenter" />
	
	<TextView
		android:id="@+id/tv_name"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:layout_marginEnd="5dp"
		android:ellipsize="middle"
		android:gravity="center_vertical"
		android:singleLine="true"
		android:textColor="?attr/main_bottom_foreground_color"
		android:textSize="16sp"
		tools:text="@string/app_name" />
</LinearLayout>