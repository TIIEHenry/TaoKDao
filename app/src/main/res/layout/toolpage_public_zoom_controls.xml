<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	android:layout_width="wrap_content"
	android:layout_height="@dimen/toolpage_public_zoom_controls_H"
	android:background="?attr/main_float_background_color"
	android:elevation="2dp">
	
	<ImageView
		android:id="@+id/iv_zoom_in"
		android:layout_width="@dimen/toolpage_public_zoom_control_iv_W"
		android:layout_height="@dimen/toolpage_public_zoom_controls_H"
		android:background="@drawable/main_float_rectangle_selector"
		android:scaleType="fitCenter"
		android:src="@drawable/toolpage_public_zoom_controls_in"
		app:layout_constraintBottom_toBottomOf="parent"
		app:layout_constraintEnd_toStartOf="@id/iv_zoom_out"
		app:layout_constraintStart_toStartOf="parent"
		app:layout_constraintTop_toTopOf="parent" />
	
	<ImageView
		android:id="@+id/iv_zoom_out"
		android:layout_width="@dimen/toolpage_public_zoom_control_iv_W"
		android:layout_height="@dimen/toolpage_public_zoom_controls_H"
		android:background="@drawable/main_float_rectangle_selector"
		android:scaleType="fitCenter"
		android:src="@drawable/toolpage_public_zoom_controls_out"
		app:layout_constraintBottom_toBottomOf="parent"
		app:layout_constraintEnd_toEndOf="parent"
		app:layout_constraintStart_toEndOf="@id/iv_zoom_in"
		app:layout_constraintTop_toTopOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>