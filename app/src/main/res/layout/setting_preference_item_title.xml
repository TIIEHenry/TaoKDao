<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="@dimen/setting_preference_item_H"
	android:padding="@dimen/setting_preference_item_group_Padding">
	
	<ImageView
		android:id="@+id/iv_icon"
		android:layout_width="@dimen/setting_preference_item_group_title_size"
		android:layout_height="@dimen/setting_preference_item_group_title_size"
		android:layout_marginBottom="@dimen/setting_preference_item_group_separator_Padding"
		android:scaleType="fitCenter"
		app:layout_constraintBottom_toTopOf="@id/v_divider"
		app:layout_constraintStart_toStartOf="parent"
		app:layout_constraintTop_toTopOf="parent"
		tools:srcCompat="@mipmap/ic_launcher_round" />
	
	<TextView
		android:id="@+id/tv_title"
		android:layout_width="wrap_content"
		android:layout_height="@dimen/setting_preference_item_group_icon_WH"
		android:layout_marginStart="@dimen/setting_preference_item_Padding"
		android:layout_marginBottom="@dimen/setting_preference_item_group_separator_Padding"
		android:gravity="clip_vertical"
		android:singleLine="true"
		android:textColor="?attr/main_content_foreground_color_hint"
		android:textSize="@dimen/setting_preference_item_group_title_size"
		app:layout_constraintBottom_toTopOf="@id/v_divider"
		app:layout_constraintStart_toEndOf="@id/iv_icon"
		app:layout_constraintTop_toTopOf="parent"
		tools:text="TIIEHenry" />
	
	<View
		android:id="@+id/v_divider"
		android:layout_width="match_parent"
		android:layout_height="1dp"
		android:background="?attr/main_content_background_color_accent"
		app:layout_constraintBottom_toBottomOf="parent"
		app:layout_constraintStart_toEndOf="@id/iv_icon" />


</androidx.constraintlayout.widget.ConstraintLayout>
