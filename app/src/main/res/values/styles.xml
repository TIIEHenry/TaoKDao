	<style name="Base.Widget.Design.TabLayout" parent="android:Widget">
		<item name="tabBackground">@android:color/transparent</item>
		<item name="tabIndicatorColor">?attr/main_appbar_foreground_color_accent</item>
		<item name="tabIndicatorHeight">2dp</item>
		<item name="tabTextAppearance">@style/TextAppearance.Design.Tab</item>
		<item name="tabSelectedTextColor">?attr/main_appbar_foreground_color_accent</item>
	</style>
	
	<style name="TextAppearance.Design.Tab" parent="TextAppearance.AppCompat.Button">
		<item name="android:textSize">15sp</item>
		<item name="android:textColor">?attr/main_appbar_foreground_color</item>
		<item name="textAllCaps">false</item>
	</style>
	
	
	<style name="Main_PluginInstaller_Dialog_TextButton" parent="Widget.AppCompat.Button">
		<item name="android:gravity">center_vertical</item>
		<item name="android:background">@drawable/main_content_rectangle_selector</item>
		<item name="android:textSize">13sp</item>
		<item name="android:textColor">?attr/main_content_foreground_color</item>
		<item name="android:lines">1</item>
		<item name="android:textAllCaps">false</item>
		<item name="android:padding">10dp</item>
		<item name="android:clickable">true</item>
	</style>
	
	
	<style name="CodeEditor_AutoComplete_PopupAnimation" mce_bogus="1" parent="android:Animation">
		<item name="android:windowEnterAnimation">@anim/editor_autocomplete_popup_enter</item>
		<item name="android:windowExitAnimation">@anim/editor_autocomplete_popup_exit</item>
	</style>
	
	<style name="Main_Content_Guide_Button" parent="Widget.AppCompat.Button">
		<item name="android:gravity">center</item>
		<item name="android:background">@drawable/contents_welcome_btn_selector</item>
		<item name="android:textSize">15sp</item>
		<item name="android:textColor">?attr/main_appbar_foreground_color</item>
		<item name="android:lines">1</item>
		<item name="android:padding">10dp</item>
		<item name="android:layout_margin">1dp</item>
		<item name="android:clickable">true</item>
		<item name="android:layout_height">60dp</item>
		<item name="android:layerType">software</item>
	</style>
	
	<style name="Base.Animation.AppCompat.Dialog" parent="android:Animation">
		<item name="android:windowEnterAnimation">@anim/dialog_enter</item>
		<item name="android:windowExitAnimation">@anim/dialog_exit</item>
	</style>
	
	<style name="Animation_MaterialDialog" parent="@android:style/Animation.Dialog">
		<item name="android:windowEnterAnimation">@anim/dialog_enter</item>
		<item name="android:windowExitAnimation">@anim/dialog_exit</item>
	</style>
	
	
	<style name="Animation_Popup_RightTop">
		<item name="android:windowEnterAnimation">@anim/popup_right_top_enter</item>
		<item name="android:windowExitAnimation">@anim/popup_right_top_exit</item>
	</style>
	
	<style name="Animation_Popup_RightBottom">
		<item name="android:windowEnterAnimation">@anim/popup_right_bottom_enter</item>
		<item name="android:windowExitAnimation">@anim/popup_right_bottom_exit</item>
	</style>
	
	<style name="Animation_Popup_LeftTop">
		<item name="android:windowEnterAnimation">@anim/popup_left_top_enter</item>
		<item name="android:windowExitAnimation">@anim/popup_left_top_exit</item>
	</style>
	
	<style name="Animation_Popup_LeftBottom">
		<item name="android:windowEnterAnimation">@anim/popup_left_bottom_enter</item>
		<item name="android:windowExitAnimation">@anim/popup_left_bottom_exit</item>
	</style>
</resources>
