<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android" android:enterFadeDuration="0" android:exitFadeDuration="700">

	<item android:state_pressed="false">
		<shape>
			<solid android:color="?attr/main_appbar_background_color_hint" />

			<stroke android:width="2dp" android:color="?attr/main_appbar_foreground_color" android:dashWidth="1dp" android:dashGap="4dp" />
		</shape>
	</item>

	<item android:state_pressed="true">
		<shape>
			<solid android:color="?attr/main_appbar_background_color_accent" />
		</shape>
	</item>
</selector>