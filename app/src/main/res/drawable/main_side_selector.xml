<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
	android:color="?attr/main_appbar_background_color_accent">
	<item>
		<selector
			android:enterFadeDuration="300"
			android:exitFadeDuration="300">
			<item android:state_pressed="false">
				<shape android:shape="rectangle">
					<solid android:color="@android:color/transparent" />
					<corners android:radius="@dimen/main_side_radius" />
				</shape>
			</item>
			<item android:state_pressed="true">
				<shape android:shape="rectangle">
					<solid android:color="?attr/main_float_background_color_accent" />
					<corners android:radius="@dimen/main_side_radius" />
				</shape>
			</item>
		</selector>
	</item>
</ripple>
