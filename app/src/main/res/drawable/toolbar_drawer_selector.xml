<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android" android:enterFadeDuration="0" android:exitFadeDuration="0">
	<item android:state_pressed="false">
		<layer-list>
			<item android:bottom="@dimen/toolbar_logo_icon_top" android:top="@dimen/toolbar_logo_icon_top">
				<shape android:shape="rectangle">
					<solid android:color="?attr/main_appbar_background_color_hint" />
					<corners android:bottomLeftRadius="@dimen/toolbar_logo_radius" android:bottomRightRadius="@dimen/toolbar_logo_radius" android:topLeftRadius="@dimen/toolbar_logo_radius" android:topRightRadius="@dimen/toolbar_logo_radius" />
				</shape>
			</item>
			<item android:left="@dimen/toolbar_logo_left">
				<shape android:shape="oval">
					<size android:width="@dimen/toolbar_logo_icon_WH" android:height="@dimen/toolbar_logo_icon_WH" />
					<solid android:color="?attr/main_appbar_background_color" />
<!--					<stroke android:width="2dp" android:color="?attr/main_appbar_background_color" />-->
<!--					<stroke android:width="4dp" android:color="?attr/main_appbar_background_color" />-->
				</shape>
			</item>
		</layer-list>
	</item>
	<item android:state_pressed="true">
		<layer-list>
			<item android:bottom="@dimen/toolbar_logo_icon_top" android:top="@dimen/toolbar_logo_icon_top">
				<shape android:shape="rectangle">
					<solid android:color="?attr/main_appbar_foreground_color" />
					<corners android:bottomLeftRadius="@dimen/toolbar_logo_radius" android:bottomRightRadius="@dimen/toolbar_logo_radius" android:topLeftRadius="@dimen/toolbar_logo_radius" android:topRightRadius="@dimen/toolbar_logo_radius" />
				</shape>
			</item>
			<item android:left="@dimen/toolbar_logo_left">
				<shape android:shape="oval">
					<size android:width="@dimen/toolbar_logo_icon_WH" android:height="@dimen/toolbar_logo_icon_WH" />
					<solid android:color="?attr/main_appbar_background_color" />
					<!--					<stroke android:width="2dp" android:color="?attr/main_appbar_background_color" />-->
					<!--					<stroke android:width="4dp" android:color="?attr/main_appbar_background_color" />-->
				</shape>
			</item>
		</layer-list>
	</item>
</selector>
