<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android" android:enterFadeDuration="0" android:exitFadeDuration="300">
	<item android:state_pressed="false">
		<shape android:shape="rectangle">
			<solid android:color="#00000000" />
			<corners android:bottomRightRadius="@dimen/toolbar_indicator_radius" android:bottomLeftRadius="0dp" android:topRightRadius="@dimen/toolbar_indicator_radius" android:topLeftRadius="0dp" />
		</shape>
	</item>
	<item android:state_pressed="true">
		<shape android:shape="rectangle">
			<solid android:color="?attr/main_appbar_foreground_color_accent" />
			<corners android:bottomRightRadius="@dimen/toolbar_indicator_radius" android:bottomLeftRadius="0dp" android:topRightRadius="@dimen/toolbar_indicator_radius" android:topLeftRadius="0dp" />
		</shape>
	</item>
</selector>
