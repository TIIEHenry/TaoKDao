<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="@dimen/plugin_launcher_list_all_item_W"
	android:layout_height="wrap_content"
	android:background="@drawable/main_content_rectangle_selector"
	android:padding="4dp">
	
	<ImageView
		android:id="@+id/iv_icon"
		android:layout_width="@dimen/plugin_launcher_list_all_item_gird_H"
		android:layout_height="@dimen/plugin_launcher_list_all_item_gird_H"
		android:padding="4dp"
		android:scaleType="fitCenter"
		app:layout_constraintBottom_toTopOf="@id/tv_label"
		app:layout_constraintEnd_toEndOf="parent"
		app:layout_constraintStart_toStartOf="parent"
		app:layout_constraintTop_toTopOf="parent"
		tools:src="@mipmap/ic_launcher" />
	
	<TextView
		android:id="@+id/tv_label"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:ellipsize="end"
		android:gravity="center"
		android:singleLine="true"
		android:textColor="?attr/main_content_foreground_color"
		android:textSize="11sp"
		app:layout_constraintBottom_toBottomOf="parent"
		app:layout_constraintEnd_toEndOf="parent"
		app:layout_constraintStart_toStartOf="parent"
		app:layout_constraintTop_toBottomOf="@id/iv_icon"
		tools:text="Manage" />
</androidx.constraintlayout.widget.ConstraintLayout>