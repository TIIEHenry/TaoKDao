{"description":"java annotation type","extension":"java","group":"Java","name":"AnnotationType","parameters":["PACKAGE_NAME","IMPORT_BLOCK","VISIBILITY","INTERFACES"],"templateText":"#if (${PACKAGE_NAME} != \"\")package ${PACKAGE_NAME};#end\n\n#if (${IMPORT_BLOCK} != \"\")${IMPORT_BLOCK}\n#end\n#if (${VISIBILITY} == \"PUBLIC\")public #end interface ${NAME} #if (${INTERFACES} != \"\")extends ${INTERFACES} #end {\n}\n"}