<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android" android:enterFadeDuration="0" android:exitFadeDuration="300">
	<item android:state_pressed="false">
		<shape android:shape="rectangle">
			<solid android:color="@color/main_bottom_background_color" />
			<corners android:bottomLeftRadius="@dimen/quick_control_btn_radius" android:topLeftRadius="@dimen/quick_control_btn_radius" />
		</shape>
	</item>
	<item android:state_pressed="true">
		<shape android:shape="rectangle">
			<solid android:color="@color/main_bottom_background_color_accent" />
			<corners android:bottomLeftRadius="@dimen/quick_control_btn_radius" android:topLeftRadius="@dimen/quick_control_btn_radius" />
		</shape>
	</item>
</selector>
